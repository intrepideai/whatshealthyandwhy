{
  "$ref": "#/definitions/products",
  "definitions": {
    "products": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "brand": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "price": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "origin": {
          "type": "string"
        },
        "certifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "url": {
          "type": "string"
        },
        "relatedTopics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality": {
          "type": "object",
          "properties": {
            "thirdPartyTested": {
              "type": "boolean"
            },
            "testingOrg": {
              "type": "string"
            },
            "purity": {
              "type": "string"
            },
            "heavyMetals": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "not-tested"
              ]
            },
            "labelAccuracy": {
              "type": "string"
            },
            "coaAvailable": {
              "type": "boolean"
            },
            "overallScore": {
              "type": "number",
              "minimum": 1,
              "maximum": 5
            }
          },
          "additionalProperties": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "brand",
        "category",
        "image",
        "price",
        "url"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}