---

<Base title="Stack Builder" description="Build your personalized supplement schedule based on evidence-based timing.">
  <div class="builder-page">
    <a href="/" class="back-link">&larr; Home</a>
    <h1>Stack Builder</h1>
    <p class="builder-intro">Select the supplements you take. We'll generate your personalized daily schedule with optimal timing for absorption and effect.</p>

    <div class="supplement-picker">
      <h2>Select your supplements</h2>
      <div class="picker-grid">
        {supplements.map((s) => (
          <label class="picker-item">
            <input type="checkbox" value={s.name} data-time={s.time} />
            <span class="picker-label">{s.name}</span>
          </label>
        ))}
      </div>
    </div>

    <div id="my-schedule" class="my-schedule" hidden>
      <h2>Your Daily Schedule</h2>
      <div id="schedule-output"></div>
      <button id="print-btn" class="print-btn">Print schedule</button>
    </div>
  </div>
</Base>

<script define:vars={{ supplements, timeOrder, timeLabels }}>
  const checkboxes = document.querySelectorAll('.picker-item input');
  const scheduleEl = document.getElementById('my-schedule');
  const outputEl = document.getElementById('schedule-output');
  const printBtn = document.getElementById('print-btn');

  function buildSchedule() {
    const selected = [];
    checkboxes.forEach(cb => {
      if (cb.checked) {
        selected.push({ name: cb.value, time: cb.dataset.time });
      }
    });

    if (selected.length === 0) {
      scheduleEl.hidden = true;
      return;
    }

    const grouped = {};
    timeOrder.forEach(t => grouped[t] = []);
    selected.forEach(s => {
      if (grouped[s.time]) grouped[s.time].push(s.name);
    });

    let html = '';
    timeOrder.forEach(time => {
      if (grouped[time].length === 0) return;
      html += `<div class="schedule-block">
        <div class="schedule-time">${timeLabels[time]}</div>
        <ul class="schedule-items">
          ${grouped[time].map(name => `<li>${name}</li>`).join('')}
        </ul>
      </div>`;
    });

    outputEl.innerHTML = html;
    scheduleEl.hidden = false;
  }

  checkboxes.forEach(cb => cb.addEventListener('change', buildSchedule));

  printBtn.addEventListener('click', () => {
    window.print();
  });
</script>

<style>
  .builder-page { max-width: 48rem; }

  .builder-intro {
    color: var(--color-text-muted); margin-bottom: var(--space-xl); line-height: 1.6;
  }

  .supplement-picker { margin-bottom: var(--space-2xl); }
  .supplement-picker h2 { margin-bottom: var(--space-md); }

  .picker-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: var(--space-xs);
  }

  .picker-item {
    display: flex; align-items: center; gap: var(--space-xs);
    padding: 0.375rem 0.5rem; border-radius: var(--radius); cursor: pointer;
    transition: background 0.1s ease;
  }
  .picker-item:hover { background: var(--color-accent-light); }
  .picker-item input { accent-color: var(--color-accent); }
  .picker-label { font-size: 0.875rem; color: var(--color-text); }

  .my-schedule h2 { margin-bottom: var(--space-md); }

  :global(.schedule-block) {
    margin-bottom: var(--space-lg); padding: var(--space-md);
    background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius);
  }
  :global(.schedule-time) {
    font-weight: 600; font-size: 0.875rem; color: var(--color-accent); margin-bottom: var(--space-xs);
  }
  :global(.schedule-items) { padding-left: var(--space-lg); }
  :global(.schedule-items li) {
    font-size: 0.9375rem; line-height: 1.6; color: var(--color-text);
  }

  .print-btn {
    margin-top: var(--space-md); padding: 0.5rem 1rem; background: none;
    border: 1px solid var(--color-border); border-radius: var(--radius);
    font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-muted);
    cursor: pointer; transition: border-color 0.15s ease, color 0.15s ease;
  }
  .print-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }

  @media print {
    .supplement-picker, .print-btn, .site-header, .site-footer, .back-link { display: none !important; }
    .my-schedule { display: block !important; }
    :global(.schedule-block) { break-inside: avoid; }
  }

  @media (max-width: 640px) {
    .picker-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
