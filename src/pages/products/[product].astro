---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map((product) => ({
    params: { product: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const content = marked.parse(product.body || '') as string;
---

<Base title={product.data.name} description={`${product.data.name} by ${product.data.brand} — independently vetted and recommended.`}>
  <div class="product-detail">
    <a href="/products" class="back-link">&larr; All Products</a>

    <div class="product-layout">
      <div class="product-detail-image">
        <img src={product.data.image} alt={product.data.name} />
      </div>

      <div class="product-detail-info">
        <span class="product-detail-brand">{product.data.brand}</span>
        <h1>{product.data.name}</h1>

        {product.data.certifications && (
          <div class="product-detail-certs">
            {product.data.certifications.map((cert: string) => (
              <span class="cert-badge-lg">{cert}</span>
            ))}
          </div>
        )}

        <div class="product-detail-meta">
          {product.data.size && <p><strong>Size:</strong> {product.data.size}</p>}
          {product.data.origin && <p><strong>Origin:</strong> {product.data.origin}</p>}
          <p><strong>Category:</strong> {product.data.category}</p>
        </div>

        <div class="product-detail-price">{product.data.price}</div>

        <a href={product.data.url} class="buy-button" target="_blank" rel="noopener noreferrer">
          Visit Product Page &rarr;
        </a>

        <p class="not-sponsored">We are not affiliated with this brand. This is an independent recommendation.</p>
      </div>
    </div>

    <div class="product-body" set:html={content} />

    {product.data.relatedTopics && product.data.relatedTopics.length > 0 && (
      <div class="related-reading">
        <h2>Related Research</h2>
        <p>Read the science behind why we recommend this product:</p>
        <ul>
          {product.data.relatedTopics.map((link: string) => (
            <li><a href={link}>{link}</a></li>
          ))}
        </ul>
      </div>
    )}
  </div>
</Base>

<style>
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    margin: var(--space-xl) 0 var(--space-2xl);
  }

  .product-detail-image {
    background: #f5f5f0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-detail-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .product-detail-brand {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .product-detail-info h1 {
    font-size: 1.6rem;
    margin-bottom: var(--space-md);
  }

  .product-detail-certs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .cert-badge-lg {
    font-size: 0.8rem;
    padding: 4px 12px;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: 999px;
    font-weight: 600;
  }

  .product-detail-meta {
    margin-bottom: var(--space-lg);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .product-detail-meta p {
    margin-bottom: var(--space-xs);
  }

  .product-detail-price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .buy-button {
    display: inline-block;
    padding: var(--space-sm) var(--space-xl);
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease;
    margin-bottom: var(--space-md);
  }

  .buy-button:hover {
    background: var(--color-accent-hover);
    text-decoration: none;
    color: white;
  }

  .not-sponsored {
    font-size: 0.8rem;
    color: var(--color-text-light);
    font-style: italic;
    margin: 0;
  }

  .product-body {
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
    line-height: 1.7;
  }

  .related-reading {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .related-reading h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  .related-reading p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
