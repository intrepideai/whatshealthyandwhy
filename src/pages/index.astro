---
import Base from '../layouts/Base.astro';
import { exploreCategories } from '../data/explore';
import { resolveTopics } from '../lib/topics';

const entryPoints = await Promise.all(
  exploreCategories.map(async (cat) => {
    const allSlugs = cat.subcategories.flatMap((s) => s.topicSlugs);
    const topics = await resolveTopics(allSlugs);
    return {
      name: cat.title,
      description: cat.tagline,
      href: `/explore/${cat.slug}`,
      count: topics.length,
    };
  }),
);
---

<Base title="What's Healthy and Why">
  <div class="home-hero">
    <h1>What's Healthy and Why</h1>
    <p>Peer-reviewed health research, explained at the depth you want.<br />Every claim is cited. Every source is real.</p>
    <div class="home-actions">
      <a href="/tools/quiz" class="action-btn primary">Start here &rarr;</a>
      <a href="/ask" class="action-btn">Ask AI</a>
      <a href="/schedule" class="action-btn">Supplement schedule</a>
      <a href="/good-for" class="action-btn">Good for...</a>
      <a href="/search" class="action-btn">Search</a>
    </div>
  </div>

  <div class="entry-grid">
    {entryPoints.map((ep) => (
      <a href={ep.href} class="entry-card">
        <h2>{ep.name}</h2>
        <p>{ep.description}</p>
        <span class="entry-count">{ep.count} {ep.count === 1 ? 'topic' : 'topics'}</span>
      </a>
    ))}
  </div>
</Base>

<style>
  .home-hero {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .home-hero h1 {
    font-size: 2.75rem;
    margin-bottom: var(--space-sm);
  }

  .home-hero p {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .home-actions {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .action-btn {
    padding: 0.5rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }

  .action-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .action-btn.primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .action-btn.primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: white;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .entry-card {
    display: block;
    padding: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .entry-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    text-decoration: none;
    transform: translateY(-2px);
  }

  .entry-card h2 {
    font-size: 1.2rem;
    margin: 0 0 var(--space-sm) 0;
    color: var(--color-text);
  }

  .entry-card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .entry-count {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: var(--color-bg);
    padding: 2px 10px;
    border-radius: 999px;
  }

  @media (max-width: 1024px) {
    .entry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .home-hero h1 {
      font-size: 1.8rem;
    }

    .home-hero {
      padding: var(--space-2xl) 0;
    }

    .entry-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
