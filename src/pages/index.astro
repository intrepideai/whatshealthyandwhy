---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allSubtopics = await getCollection('topics');

// Group subtopics by topic name
const topicMap = new Map<string, { slug: string; description: string; subtopicCount: number }>();

for (const entry of allSubtopics) {
  const topicName = entry.data.topic;
  const slug = topicName.toLowerCase().replace(/\s+/g, '-');

  if (!topicMap.has(topicName)) {
    topicMap.set(topicName, { slug, description: '', subtopicCount: 0 });
  }

  const topic = topicMap.get(topicName)!;
  topic.subtopicCount++;

  if (topic.subtopicCount === 1 || entry.data.order === 1) {
    topic.description = entry.data.description;
  }
}

const topics = Array.from(topicMap.entries()).map(([name, data]) => ({ name, ...data }));

// Define categories and assign topics
const categories = [
  {
    name: 'Hidden Dangers in Food',
    description: 'What\'s really in your food and why it matters.',
    slugs: ['seed-oils', 'food-additives', 'artificial-sweeteners', 'farm-raised-fish', 'lectins'],
  },
  {
    name: 'Supplements & Natural Compounds',
    description: 'What the science says about popular supplements and natural compounds.',
    slugs: ['turmeric', 'omega-3-fatty-acids', 'vitamin-d', 'vitamin-c', 'vitamin-k2', 'b-vitamins', 'magnesium', 'zinc', 'iodine', 'selenium', 'ashwagandha', 'probiotics', 'creatine', 'collagen', 'coq10', 'nac', 'berberine', 'melatonin', 'resveratrol'],
  },
  {
    name: 'Foods & Drinks',
    description: 'How what you eat and drink affects your health.',
    slugs: ['tea', 'anti-inflammatory-foods', 'medicinal-mushrooms', 'olive-oil', 'bone-broth', 'honey', 'apple-cider-vinegar', 'fermented-foods', 'eggs', 'berries', 'dark-chocolate', 'nuts-and-seeds', 'coconut-oil', 'organ-meats', 'grass-fed-meat', 'raw-milk'],
  },
  {
    name: 'Herbs & Spices',
    description: 'Nature\'s medicine cabinet — the research behind everyday herbs and spices.',
    slugs: ['garlic', 'onions', 'ginger', 'cinnamon', 'oregano-oil', 'black-seed-oil', 'elderberry', 'moringa', 'wormwood', 'cloves'],
  },
  {
    name: 'Therapeutic Practices',
    description: 'Evidence-based therapies and healing modalities.',
    slugs: ['sauna', 'cold-exposure', 'prp', 'red-light-therapy', 'grounding', 'dry-brushing', 'oil-pulling', 'acupuncture', 'massage', 'forest-bathing'],
  },
  {
    name: 'Exercise & Movement',
    description: 'Move your body — the research on what works and how much you need.',
    slugs: ['resistance-training', 'walking', 'zone-2-cardio', 'stretching-mobility', 'rebounding'],
  },
  {
    name: 'Detox & Cleansing',
    description: 'Supporting your body\'s natural detoxification pathways.',
    slugs: ['parasite-cleansing', 'liver-cleansing', 'heavy-metal-detox', 'spirulina-chlorella', 'activated-charcoal', 'bentonite-clay', 'diatomaceous-earth', 'black-walnut-hull', 'milk-thistle', 'dandelion-root'],
  },
  {
    name: 'Skin & Body Care',
    description: 'Natural alternatives for what you put on your body.',
    slugs: ['castor-oil', 'tallow', 'aloe-vera', 'sunscreen', 'personal-care-products'],
  },
  {
    name: 'Your Home',
    description: 'What\'s in your air, water, furniture, and cleaning products.',
    slugs: ['household-chemicals', 'indoor-air-quality', 'water-filtration', 'mattresses-&-furniture', 'non-stick-cookware'],
  },
  {
    name: 'Environmental Toxins',
    description: 'The invisible chemicals accumulating in your body and environment.',
    slugs: ['microplastics', 'pfas-(forever-chemicals)', 'glyphosate-(roundup)', 'fluoride', 'mold', 'emf'],
  },
  {
    name: 'Body Systems',
    description: 'Understanding and supporting your body\'s core systems.',
    slugs: ['thyroid-health', 'hormone-balance', 'adrenal-health', 'leaky-gut', 'dental-health', 'eye-health', 'seed-cycling'],
  },
  {
    name: 'Wellness & Lifestyle',
    description: 'Building healthy habits backed by research.',
    slugs: ['sleep', 'mouth-breathing', 'intermittent-fasting', 'meditation-breathwork', 'vagus-nerve', 'sunlight', 'electrolytes', 'posture', 'digital-detox', 'journaling'],
  },
];

// Build category data with matched topics
const categoryData = categories.map((cat) => ({
  ...cat,
  topics: cat.slugs
    .map((s) => topics.find((t) => t.slug === s))
    .filter(Boolean),
}));
---

<Base title="What's Healthy and Why">
  <div class="site-intro">
    <h1>What's Healthy and Why</h1>
    <p>Peer-reviewed health research, explained at the depth you want. Every claim is cited. Every source is real.</p>
    <a href="/levels" class="levels-banner">New here? Start with our 5-level health journey &rarr;</a>
  </div>

  <div class="categories-grid">
    {categoryData.map((cat, i) => (
      <details class="category-card" open={i === 0}>
        <summary class="category-summary">
          <div>
            <h2>{cat.name}</h2>
            <p>{cat.description}</p>
          </div>
          <span class="category-count">{cat.topics.length} topics</span>
        </summary>
        <div class="topic-grid">
          {cat.topics.map((topic: any) => (
            <a href={`/${topic.slug}`} class="topic-card">
              <h3>{topic.name}</h3>
              <p>{topic.description}</p>
              <span class="topic-count">{topic.subtopicCount} {topic.subtopicCount === 1 ? 'article' : 'articles'}</span>
            </a>
          ))}
        </div>
      </details>
    ))}
  </div>
</Base>

<style>
  .categories-grid {
    display: grid;
    gap: var(--space-md);
  }

  .category-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .category-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) var(--space-xl);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.15s ease;
  }

  .category-summary::-webkit-details-marker {
    display: none;
  }

  .category-summary::marker {
    display: none;
    content: '';
  }

  .category-summary:hover {
    background: var(--color-bg);
  }

  .category-summary h2 {
    font-size: 1.15rem;
    margin: 0 0 2px 0;
  }

  .category-summary p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .category-count {
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: var(--color-bg);
    padding: 2px 10px;
    border-radius: 999px;
    margin-left: var(--space-md);
  }

  .category-card[open] .category-summary {
    border-bottom: 1px solid var(--color-border-light);
  }

  .category-card .topic-grid {
    padding: var(--space-md) var(--space-lg) var(--space-lg);
  }

  @media (max-width: 640px) {
    .category-summary {
      padding: var(--space-md);
    }

    .category-card .topic-grid {
      padding: var(--space-sm) var(--space-md) var(--space-md);
    }
  }
</style>
