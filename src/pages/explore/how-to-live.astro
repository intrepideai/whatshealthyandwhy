  { name: 'Therapeutic Practices', slugs: ['sauna', 'cold-exposure', 'contrast-therapy', 'float-tanks', 'hyperbaric-oxygen', 'prp', 'red-light-therapy', 'grounding', 'dry-brushing', 'oil-pulling', 'acupuncture', 'massage', 'forest-bathing', 'neurofeedback', 'pemf-therapy', 'biofeedback'] },
  { name: 'Wellness & Lifestyle', slugs: ['sleep', 'mouth-breathing', 'intermittent-fasting', 'ketogenic-diet', 'mediterranean-diet', 'blue-zones', 'meditation-breathwork', 'vagus-nerve', 'sunlight', 'posture', 'digital-detox', 'journaling'] },
];
---

<CategoryPage
  title="How to Live"
  description="Exercise, sleep, fasting, breathwork, and daily practices for a healthier life."
