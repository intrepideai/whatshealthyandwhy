---
import CategoryPage from '../../components/CategoryPage.astro';

const subcategories = [
  { name: 'Skin Conditions', slugs: ['acne', 'rosacea', 'eczema', 'psoriasis', 'hair-loss', 'vitiligo'] },
  { name: 'Natural Skincare', slugs: ['castor-oil', 'tallow', 'aloe-vera', 'coconut-oil', 'jojoba-oil', 'tamanu-oil', 'witch-hazel', 'skin-microbiome', 'bakuchiol', 'ghk-cu'] },
  { name: 'What to Avoid', slugs: ['sunscreen', 'personal-care-products'] },
  { name: 'Dental Health', slugs: ['dental-health', 'fluoride', 'oil-pulling'] },
  { name: 'Medicinal Oils', slugs: ['essential-oils', 'tea-tree-oil'] },
];
---

<CategoryPage
  title="Skin & Self Care"
  description="Natural alternatives for what you put on your body — from skincare to dental health to essential oils."
  subcategories={subcategories}
/>
