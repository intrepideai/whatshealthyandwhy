---
import Base from '../layouts/Base.astro';
---

<Base title="Ask a Question" description="Ask our AI assistant about health topics, supplements, and natural approaches.">
  <div class="chat-container">
    <div class="chat-header">
      <a href="/" class="back-link">&larr; Home</a>
      <h1>Ask a Question</h1>
      <p>Ask anything about health, supplements, natural remedies, or what to avoid. Answers are informed by the research on this site.</p>
      <p class="chat-disclaimer">Not medical advice. Always consult a healthcare provider for serious conditions.</p>
    </div>

    <div class="chat-messages" id="chat-messages">
      <div class="chat-message assistant">
        <div class="message-content">
          <p>Hi! I can help you find information about health topics, supplements, natural remedies, and more. Try asking things like:</p>
          <ul>
            <li>"What helps with inflammation?"</li>
            <li>"Is turmeric actually effective?"</li>
            <li>"What should I look for in a water filter?"</li>
            <li>"How do I start eating healthier?"</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="chat-input-area">
      <form id="chat-form">
        <input
          type="text"
          id="chat-input"
          placeholder="Ask a health question..."
          autocomplete="off"
        />
        <button type="submit" id="chat-send">Send</button>
      </form>
    </div>
  </div>
</Base>

<script>
  // Chat UI ready for LLM connection
  // Currently shows a placeholder response — replace the getResponse function
  // with your API call when you connect the LLM

  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const messages = document.getElementById('chat-messages')!;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;

  function addMessage(text: string, role: 'user' | 'assistant') {
    const div = document.createElement('div');
    div.className = `chat-message ${role}`;
    div.innerHTML = `<div class="message-content"><p>${text}</p></div>`;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function addTyping() {
    const div = document.createElement('div');
    div.className = 'chat-message assistant typing';
    div.id = 'typing-indicator';
    div.innerHTML = '<div class="message-content"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    const el = document.getElementById('typing-indicator');
    if (el) el.remove();
  }

  const conversationHistory: { role: string; content: string }[] = [];

  async function getResponse(question: string): Promise<string> {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ question, history: conversationHistory }),
    });
    const data = await res.json();

    if (!res.ok) {
      return data.error || 'Something went wrong. Please try again.';
    }

    conversationHistory.push({ role: 'user', content: question });
    conversationHistory.push({ role: 'assistant', content: data.answer });

    // Convert markdown-like formatting to HTML
    return data.answer
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\n\n/g, '</p><p>')
      .replace(/\n- /g, '</p><li>')
      .replace(/PMID:\s*(\d+)/g, '<a href="https://pubmed.ncbi.nlm.nih.gov/$1/" target="_blank" rel="noopener noreferrer">PMID: $1</a>');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const q = input.value.trim();
    if (!q) return;

    addMessage(q, 'user');
    input.value = '';
    sendBtn.disabled = true;
    addTyping();

    try {
      const answer = await getResponse(q);
      removeTyping();
      addMessage(answer, 'assistant');
    } catch (err) {
      removeTyping();
      addMessage('Something went wrong. Please try again.', 'assistant');
    }

    sendBtn.disabled = false;
    input.focus();
  });
</script>

<style>
  .chat-container {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 200px);
    min-height: 400px;
  }

  .chat-header {
    flex-shrink: 0;
    margin-bottom: var(--space-lg);
  }

  .chat-header h1 {
    margin-bottom: var(--space-xs);
  }

  .chat-header p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    max-width: 36rem;
  }

  .chat-disclaimer {
    font-style: italic;
    color: var(--color-text-light) !important;
    font-size: 0.8rem !important;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-md) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .chat-message {
    max-width: 85%;
  }

  .chat-message.user {
    align-self: flex-end;
  }

  .chat-message.assistant {
    align-self: flex-start;
  }

  .message-content {
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-lg);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .user .message-content {
    background: var(--color-accent);
    color: white;
  }

  .user .message-content a {
    color: white;
    text-decoration: underline;
  }

  .assistant .message-content {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .assistant .message-content p {
    margin-bottom: var(--space-sm);
  }

  .assistant .message-content p:last-child {
    margin-bottom: 0;
  }

  .assistant .message-content ul {
    margin: var(--space-sm) 0 0;
    padding-left: var(--space-lg);
  }

  .assistant .message-content li {
    margin-bottom: var(--space-xs);
    color: var(--color-text-muted);
  }

  .typing .message-content {
    display: flex;
    gap: 4px;
    padding: var(--space-md) var(--space-lg);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-text-light);
    animation: bounce 1.4s infinite ease-in-out;
  }

  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  .chat-input-area {
    flex-shrink: 0;
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  #chat-form {
    display: flex;
    gap: var(--space-sm);
  }

  #chat-input {
    flex: 1;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-family: var(--font-body);
    font-size: 0.95rem;
    background: var(--color-surface);
    color: var(--color-text);
    outline: none;
  }

  #chat-input:focus {
    border-color: var(--color-accent);
  }

  #chat-send {
    padding: var(--space-sm) var(--space-xl);
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  #chat-send:hover {
    background: var(--color-accent-hover);
  }

  #chat-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
