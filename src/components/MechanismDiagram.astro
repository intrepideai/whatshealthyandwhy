---
interface Step {
  label: string;
  detail?: string;
}

interface Props {
  title: string;
  steps: Step[];
  source?: string;
}

const { title, steps, source } = Astro.props;
---

<div class="mechanism-diagram">
  <h3 class="diagram-title">{title}</h3>
  <div class="diagram-flow">
    {steps.map((step, i) => (
      <>
        <div class="diagram-step">
          <div class="step-circle">{i + 1}</div>
          <div class="step-content">
            <span class="step-label">{step.label}</span>
            {step.detail && <span class="step-detail">{step.detail}</span>}
          </div>
        </div>
        {i < steps.length - 1 && (
          <div class="diagram-arrow">
            <svg width="20" height="24" viewBox="0 0 20 24" fill="none">
              <path d="M10 0 L10 18 M4 14 L10 20 L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        )}
      </>
    ))}
  </div>
  {source && <p class="diagram-source">{source}</p>}
</div>

<style>
  .mechanism-diagram {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .diagram-title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    text-align: center;
  }

  .diagram-flow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .diagram-step {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    width: 100%;
    max-width: 28rem;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
  }

  .step-circle {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: #fff;
    border-radius: 50%;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .step-content {
    display: flex;
    flex-direction: column;
  }

  .step-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .step-detail {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .diagram-arrow {
    color: var(--color-text-light);
    padding: 0.25rem 0;
  }

  .diagram-source {
    text-align: center;
    margin-top: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-light);
    font-style: italic;
  }
</style>
