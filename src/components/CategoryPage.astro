---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

interface SubCategory {
  name: string;
  slugs: string[];
}

interface Props {
  title: string;
  description: string;
  subcategories: SubCategory[];
}

const { title, description, subcategories } = Astro.props;

const allSubtopics = await getCollection('topics');

// Build topic map
const topicMap = new Map<string, { slug: string; description: string; subtopicCount: number }>();
for (const entry of allSubtopics) {
  const topicName = entry.data.topic;
  const slug = topicName.toLowerCase().replace(/\s+/g, '-');
  if (!topicMap.has(topicName)) {
    topicMap.set(topicName, { slug, description: '', subtopicCount: 0 });
  }
  const topic = topicMap.get(topicName)!;
  topic.subtopicCount++;
  if (topic.subtopicCount === 1 || entry.data.order === 1) {
    topic.description = entry.data.description;
  }
}

const topics = Array.from(topicMap.entries()).map(([name, data]) => ({ name, ...data }));

const subCatData = subcategories.map((sc) => ({
  ...sc,
  topics: sc.slugs
    .map((s) => topics.find((t) => t.slug === s))
    .filter(Boolean),
}));
---

<Base title={title} description={description}>
  <div class="cat-header">
    <a href="/" class="back-link">&larr; Home</a>
    <h1>{title}</h1>
    <p class="cat-description">{description}</p>
  </div>

  {subCatData.map((sc) => (
    <section class="cat-section">
      <h2>{sc.name}</h2>
      <div class="topic-grid">
        {sc.topics.map((topic: any) => (
          <a href={`/${topic.slug}`} class="topic-card">
            <h3>{topic.name}</h3>
            <p>{topic.description}</p>
            <span class="topic-count">{topic.subtopicCount} {topic.subtopicCount === 1 ? 'article' : 'articles'}</span>
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  .cat-header {
    margin-bottom: var(--space-2xl);
  }

  .cat-header h1 {
    margin-bottom: var(--space-xs);
  }

  .cat-description {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 36rem;
  }

  .cat-section {
    margin-bottom: var(--space-2xl);
  }

  .cat-section h2 {
    font-size: 1.15rem;
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
  }
</style>
