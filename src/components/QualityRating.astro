---
interface Quality {
  thirdPartyTested?: boolean;
  testingOrg?: string;
  purity?: string;
  heavyMetals?: 'pass' | 'fail' | 'not-tested';
  labelAccuracy?: string;
  coaAvailable?: boolean;
  overallScore?: number;
}

interface Props {
  quality?: Quality;
}

const { quality } = Astro.props;
if (!quality) return;

const scoreLabels = ['', 'Poor', 'Below Average', 'Average', 'Good', 'Excellent'];
const scoreLabel = quality.overallScore ? scoreLabels[quality.overallScore] : '';
const fills = quality.overallScore ? Array.from({ length: 5 }, (_, i) => i < quality.overallScore!) : [];

const heavyMetalLabels = { pass: 'Pass', fail: 'Fail', 'not-tested': 'Not tested' };
const heavyMetalColors = { pass: 'tag-pass', fail: 'tag-fail', 'not-tested': 'tag-neutral' };
---

<div class="quality-rating">
  <div class="quality-header">
    <span class="quality-label">Quality Rating</span>
    {scoreLabel && <span class="quality-score">{scoreLabel}</span>}
  </div>

  {quality.overallScore && (
    <div class="quality-dots">
      {fills.map((filled) => (
        <span class={`quality-dot ${filled ? 'filled' : ''}`} />
      ))}
    </div>
  )}

  <div class="quality-details">
    {quality.thirdPartyTested !== undefined && (
      <div class="quality-row">
        <span class="quality-row-label">Third-party tested</span>
        <span class={`quality-tag ${quality.thirdPartyTested ? 'tag-pass' : 'tag-fail'}`}>
          {quality.thirdPartyTested ? 'Yes' : 'No'}
        </span>
      </div>
    )}
    {quality.testingOrg && (
      <div class="quality-row">
        <span class="quality-row-label">Tested by</span>
        <span class="quality-row-value">{quality.testingOrg}</span>
      </div>
    )}
    {quality.heavyMetals && (
      <div class="quality-row">
        <span class="quality-row-label">Heavy metals</span>
        <span class={`quality-tag ${heavyMetalColors[quality.heavyMetals]}`}>
          {heavyMetalLabels[quality.heavyMetals]}
        </span>
      </div>
    )}
    {quality.purity && (
      <div class="quality-row">
        <span class="quality-row-label">Purity</span>
        <span class="quality-row-value">{quality.purity}</span>
      </div>
    )}
    {quality.labelAccuracy && (
      <div class="quality-row">
        <span class="quality-row-label">Label accuracy</span>
        <span class="quality-row-value">{quality.labelAccuracy}</span>
      </div>
    )}
    {quality.coaAvailable !== undefined && (
      <div class="quality-row">
        <span class="quality-row-label">COA available</span>
        <span class={`quality-tag ${quality.coaAvailable ? 'tag-pass' : 'tag-neutral'}`}>
          {quality.coaAvailable ? 'Yes' : 'No'}
        </span>
      </div>
    )}
  </div>
</div>

<style>
  .quality-rating {
    margin: var(--space-lg) 0;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .quality-header {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-xs);
  }
  .quality-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-light); }
  .quality-score { font-size: 0.8rem; font-weight: 600; color: var(--color-text); }

  .quality-dots { display: flex; gap: 4px; margin-bottom: var(--space-md); }
  .quality-dot { width: 100%; height: 4px; border-radius: 2px; background: var(--color-border); }
  .quality-dot.filled { background: var(--color-accent); }

  .quality-details { display: flex; flex-direction: column; gap: var(--space-xs); }
  .quality-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.8125rem; }
  .quality-row-label { color: var(--color-text-muted); }
  .quality-row-value { color: var(--color-text); font-weight: 500; }

  .quality-tag {
    font-size: 0.75rem; font-weight: 600; padding: 0.125rem 0.5rem; border-radius: 1rem;
  }
  .tag-pass { background: var(--color-accent-light); color: var(--color-accent); }
  .tag-fail { background: #fef2f2; color: #991b1b; }
  .tag-neutral { background: #f5f5f0; color: var(--color-text-muted); }
</style>
